rules_version = '2';

// Sisi Travel CRM — Firestore security rules
//
// These rules restrict the `leads` collection so that ONLY signed-in users
// (i.e. agents you have created in Firebase Authentication) can read or
// write any lead. Anyone who is not signed in gets a permission-denied
// error — including anyone who finds your public URL.
//
// To deploy: Firebase Console → Firestore Database → Rules → paste this
// whole file → Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    // Leads collection — readable & writable only by authenticated users.
    match /leads/{leadId} {
      allow read, write: if request.auth != null;
    }

    // OPTIONAL — restrict to a specific email domain (e.g. @sisitravel.com.eg).
    // If you want to use this instead, comment out the rule above and
    // uncomment the rule below:
    //
    // match /leads/{leadId} {
    //   allow read, write: if request.auth != null
    //     && request.auth.token.email.matches('.*@sisitravel\\.com\\.eg$');
    // }

    // Block everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
